---
import { t } from '../i18n/translations';
const s = t(Astro.currentLocale);
---

<section class="local">
  <div class="wrap center">
    <p class="eyebrow">{s.local.eyebrow}</p>
    <h2 class="step-5">{s.local.heading}</h2>
    <p class="lede">{s.local.lede}</p>

    <ul class="chips reveal" aria-label="Bangladesh divisions">
      {s.local.divisions.map((d) => (
        <li>{d}</li>
      ))}
    </ul>
  </div>
</section>

<style>
  .local { padding-block: clamp(2.5rem, 6vw, 4.5rem); }
  .center { text-align: center; }
  .local .eyebrow { display: inline-flex; }
  h2.step-5 {
    font-size: var(--step-5);
    color: var(--forest);
    margin-top: 0.85rem;
  }
  @media (prefers-color-scheme: dark) {
    h2.step-5 { color: var(--ink); }
  }
  .lede {
    max-width: 50ch;
    margin: 1rem auto 0;
    color: var(--ink-soft);
  }
  .chips {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
    margin: 2.25rem 0 0;
    padding: 0;
  }
  .chips li {
    padding: 0.5em 1.1em;
    border-radius: 999px;
    background: var(--paper-card);
    border: 1px solid rgba(16, 56, 41, 0.14);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--forest);
  }
  @media (prefers-color-scheme: dark) {
    .chips li {
      border-color: rgba(234, 241, 230, 0.14);
      color: var(--ink);
    }
  }
</style>
