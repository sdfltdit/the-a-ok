---
import { t } from '../i18n/translations';
const s = t(Astro.currentLocale);
---

<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{s.hero.eyebrow}</p>
      <h1 class="step-6">
        {s.hero.headline.map((line) => <>{line}<br /></>)}
      </h1>
      <p class="tagline bn">{s.hero.tagline}</p>
      <p class="lede">{s.hero.lede}</p>
      <div class="hero-actions">
        <a href="#join" class="btn btn-primary">{s.hero.ctaPrimary}</a>
        <a href="#explore" class="btn btn-ghost">{s.hero.ctaSecondary}</a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="video-frame">
        <video poster="/images/hero-poster.webp" muted loop playsinline autoplay preload="auto" fetchpriority="high">
          <source src="/video/the-a-ok.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(2.5rem, 6vw, 5.5rem) clamp(3rem, 7vw, 6rem);
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .hero-copy .eyebrow { margin-bottom: 1.1rem; }
  h1.step-6 {
    font-size: var(--step-6);
    color: var(--forest);
  }
  @media (prefers-color-scheme: dark) {
    h1.step-6 { color: var(--ink); }
  }
  .tagline {
    font-size: var(--step-3);
    color: var(--forest);
    margin-top: 0.9rem;
  }
  @media (prefers-color-scheme: dark) {
    .tagline { color: var(--marigold-deep); }
  }
  .lede {
    max-width: 46ch;
    margin-top: 1.35rem;
    font-size: 1.08rem;
    color: var(--ink-soft);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.1rem;
  }
  .btn-ghost { color: var(--forest); }
  @media (prefers-color-scheme: dark) {
    .btn-ghost { color: var(--ink); }
  }

  .hero-visual { position: relative; }
  .video-frame {
    position: relative;
    border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    box-shadow: 0 30px 60px -25px rgba(16, 56, 41, 0.35);
    background: var(--forest);
  }
  .video-frame video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 880px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-visual { order: -1; max-width: 420px; margin-inline: auto; width: 100%; }
  }
</style>

<script>
  // Respect reduced-motion: don't force autoplay: true videos to play.
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReduced) {
    document.querySelectorAll('.video-frame video').forEach((v) => {
      const video = v as HTMLVideoElement;
      video.removeAttribute('autoplay');
      video.pause();
      video.preload = 'metadata';
    });
  }
</script>
