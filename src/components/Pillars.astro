---
import { Image } from 'astro:assets';
import learnImage from '../assets/images/learn-source.jpg';
import { t } from '../i18n/translations';
const s = t(Astro.currentLocale);
---

<section class="pillars">
  <div class="wrap">
    <p class="eyebrow center">{s.pillars.eyebrow}</p>
    <h2 class="step-5 center">{s.pillars.heading}</h2>

    <div class="grid">
      {s.pillars.items.map((p) => (
        <article id={p.id} class="card reveal">
          <div class="card-media">
            {p.id === 'learn' ? (
              <Image
                src={learnImage}
                alt=""
                width={600}
                height={450}
                widths={[400, 600, 900]}
                sizes="(max-width: 880px) 100vw, 33vw"
                format="webp"
                quality={68}
                loading="lazy"
              />
            ) : (
              <img
                src={`/images/${p.id === 'explore' ? 'Explore.avif' : 'connect.webp'}`}
                alt=""
                width="600"
                height="450"
                loading="lazy"
              />
            )}
          </div>
          <div class="card-body">
            <span class="num">{p.num}</span>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .pillars { padding-block: clamp(3rem, 7vw, 6rem); }
  .center { text-align: center; }
  .pillars .eyebrow.center { display: flex; justify-content: center; }
  h2.step-5 {
    font-size: var(--step-5);
    color: var(--forest);
    margin-top: 0.75rem;
    margin-inline: auto;
  }
  @media (prefers-color-scheme: dark) {
    h2.step-5 { color: var(--ink); }
  }
  .grid {
    margin-top: clamp(2.25rem, 5vw, 3.5rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.25rem, 3vw, 2rem);
  }
  .card {
    background: var(--paper-card);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(16, 56, 41, 0.08);
    transition: transform 0.35s var(--ease), box-shadow 0.35s var(--ease);
  }
  @media (prefers-color-scheme: dark) {
    .card { border-color: rgba(234, 241, 230, 0.1); }
  }
  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 40px -24px rgba(16, 56, 41, 0.35);
  }
  .card-media { aspect-ratio: 4 / 3; overflow: hidden; }
  .card-media img { width: 100%; height: 100%; object-fit: cover; }
  .card-body { padding: 1.5rem 1.6rem 1.9rem; }
  .num {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--marigold-deep);
    letter-spacing: 0.08em;
  }
  .card h3 {
    margin-top: 0.4rem;
    font-size: 1.5rem;
    color: var(--forest);
  }
  @media (prefers-color-scheme: dark) {
    .card h3 { color: var(--ink); }
  }
  .card p {
    margin-top: 0.6rem;
    color: var(--ink-soft);
    font-size: 0.98rem;
  }

  @media (max-width: 880px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
