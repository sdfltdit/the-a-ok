---
import ScallopDivider from './ScallopDivider.astro';
import { t } from '../i18n/translations';
const s = t(Astro.currentLocale);
---

<ScallopDivider tone="onForest" flip />
<section class="join" id="join">
  <div class="wrap join-inner">
    <div class="join-copy">
      <p class="eyebrow light">{s.join.eyebrow}</p>
      <h2 class="step-5">{s.join.heading}</h2>
      <p class="lede">{s.join.lede}</p>
    </div>

    <form
      class="join-form"
      id="join-form"
      novalidate
      data-success-template={s.join.success}
      data-error-message={s.join.error}
    >
      <label class="visually-hidden" for="email">Email address</label>
      <input
        id="email"
        name="email"
        type="email"
        required
        placeholder={s.join.placeholder}
        autocomplete="email"
      />
      <button type="submit" class="btn btn-primary">{s.join.button}</button>
    </form>
    <p id="join-status" class="join-status" role="status" aria-live="polite"></p>
  </div>
</section>

<style>
  .join {
    background: var(--forest);
    color: var(--on-forest);
    padding-block: clamp(3rem, 7vw, 5.5rem);
  }
  .join-inner { text-align: center; }
  .eyebrow.light { color: var(--marigold); justify-content: center; display: inline-flex; }
  h2.step-5 { font-size: var(--step-5); color: var(--on-forest); margin-top: 0.85rem; }
  .join-copy .lede {
    max-width: 46ch;
    margin: 1rem auto 0;
    color: var(--on-forest-soft);
  }
  .join-form {
    margin: 2.25rem auto 0;
    display: flex;
    gap: 0.75rem;
    max-width: 460px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .join-form input {
    flex: 1 1 240px;
    padding: 0.9em 1.1em;
    border-radius: 999px;
    border: 1.5px solid rgba(241, 244, 236, 0.35);
    background: rgba(241, 244, 236, 0.08);
    color: var(--on-forest);
    font-size: 1rem;
  }
  .join-form input::placeholder { color: rgba(241, 244, 236, 0.55); }
  .join-form input:focus-visible { outline-color: var(--marigold); }
  .join-status {
    margin-top: 1rem;
    min-height: 1.2em;
    font-weight: 600;
    color: var(--marigold);
  }
</style>

<script>
  const form = document.getElementById('join-form') as HTMLFormElement | null;
  const status = document.getElementById('join-status');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]') as HTMLInputElement | null;
    const successTemplate = form.dataset.successTemplate || "Thanks — we'll email {email} when we open.";
    const errorMessage = form.dataset.errorMessage || 'Please enter a valid email address.';
    if (input && input.checkValidity() && input.value.trim()) {
      status!.textContent = successTemplate.replace('{email}', input.value.trim());
      form.reset();
    } else {
      status!.textContent = errorMessage;
    }
  });
</script>
