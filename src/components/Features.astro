---
const rows = [
  {
    eyebrow: 'দক্ষতা যা কাজে লাগে · Skills that travel',
    heading: 'Taught by people three steps ahead of you, not thirty.',
    copy: "Every workshop on The A-OK comes from someone who's actually done the job — a working designer, a founder, a nurse on shift — not a generic syllabus.",
    img: '/images/skill.jpg',
    alt: 'A hands-on skills workshop in progress',
    reverse: false,
  },
  {
    eyebrow: 'একা ভাবতে হবে না · Never figure it out alone',
    heading: "Find the three people who've solved your exact problem.",
    copy: 'Ask a question, share a win, or find a study group or job-hunt partner in your district — small, specific circles instead of one noisy feed.',
    img: '/images/shared.jpg',
    alt: 'People sharing knowledge and helping each other',
    reverse: true,
  },
];
---

<section class="features">
  <div class="wrap">
    {rows.map((r) => (
      <div class:list={['row', { reverse: r.reverse }]}>
        <div class="row-media reveal">
          <img src={r.img} alt={r.alt} width="800" height="600" loading="lazy" />
        </div>
        <div class="row-copy reveal">
          <p class="eyebrow bn">{r.eyebrow}</p>
          <h3 class="step-4">{r.heading}</h3>
          <p class="lede">{r.copy}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .features { padding-block: clamp(2rem, 5vw, 3rem); }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .row.reverse .row-media { order: 2; }
  .row-media img {
    border-radius: var(--radius-md);
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  h3.step-4 {
    font-size: var(--step-4);
    color: var(--forest);
    margin-top: 0.6rem;
  }
  .row-copy .lede {
    margin-top: 1.1rem;
    max-width: 42ch;
    color: var(--ink-soft);
  }

  @media (max-width: 820px) {
    .row, .row.reverse { grid-template-columns: 1fr; }
    .row.reverse .row-media { order: -1; }
  }
</style>
