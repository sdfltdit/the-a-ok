---
import { t } from '../i18n/translations';
const s = t(Astro.currentLocale);
const images = ['/images/skill.webp', '/images/shared.webp'];
const alts = [
  'A hands-on skills workshop in progress',
  'People sharing knowledge and helping each other',
];
---

<section class="features">
  <div class="wrap">
    {s.features.rows.map((r, i) => (
      <div class:list={['row', { reverse: i === 1 }]}>
        <div class="row-media reveal">
          <img src={images[i]} alt={alts[i]} width="800" height="600" loading="lazy" />
        </div>
        <div class="row-copy reveal">
          <p class="eyebrow">{r.eyebrow}</p>
          <h3 class="step-4">{r.heading}</h3>
          <p class="lede">{r.copy}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .features { padding-block: clamp(2rem, 5vw, 3rem); }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    padding-block: clamp(2rem, 5vw, 3.5rem);
  }
  .row.reverse .row-media { order: 2; }
  .row-media img {
    border-radius: var(--radius-md);
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }
  h3.step-4 {
    font-size: var(--step-4);
    color: var(--forest);
    margin-top: 0.6rem;
  }
  @media (prefers-color-scheme: dark) {
    h3.step-4 { color: var(--ink); }
  }
  .row-copy .lede {
    margin-top: 1.1rem;
    max-width: 42ch;
    color: var(--ink-soft);
  }

  @media (max-width: 820px) {
    .row, .row.reverse { grid-template-columns: 1fr; }
    .row.reverse .row-media { order: -1; }
  }
</style>
