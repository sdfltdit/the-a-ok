---
import ScallopDivider from './ScallopDivider.astro';
---

<ScallopDivider tone="onPaper" />
<section class="mission">
  <div class="wrap mission-grid">
    <div class="mission-copy reveal">
      <p class="eyebrow light">কেন দ্য এ-ওকে · Why we exist</p>
      <h2 class="step-5">
        Opportunity in Bangladesh shouldn't depend on who you already know.
      </h2>
      <p class="lede">
        Too much of what's genuinely useful — the right course, the right
        community, the right next step — still travels by word of mouth. The
        A-OK puts it in one open place, so it just takes a search, not a
        connection.
      </p>
    </div>
    <div class="mission-image reveal">
      <img
        src="/images/challenging.webp"
        alt="A person navigating everyday life and work in Bangladesh"
        width="2000"
        height="1333"
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .mission {
    background: var(--forest);
    color: var(--paper);
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .eyebrow.light { color: var(--marigold); }
  h2.step-5 {
    font-size: var(--step-5);
    color: var(--paper);
    margin-top: 1rem;
  }
  .mission-copy .lede {
    margin-top: 1.35rem;
    max-width: 46ch;
    color: rgba(241, 244, 236, 0.82);
    font-size: 1.06rem;
  }
  .mission-image img {
    border-radius: var(--radius-lg);
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 11;
  }
  @media (max-width: 860px) {
    .mission-grid { grid-template-columns: 1fr; }
    .mission-image { order: -1; }
  }
</style>
