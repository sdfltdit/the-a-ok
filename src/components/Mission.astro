---
import { Image } from 'astro:assets';
import challengingImage from '../assets/images/challenging-source.webp';
import ScallopDivider from './ScallopDivider.astro';
import { t } from '../i18n/translations';
const s = t(Astro.currentLocale);
---

<ScallopDivider tone="onPaper" />
<section class="mission">
  <div class="wrap mission-grid">
    <div class="mission-copy reveal">
      <p class="eyebrow light">{s.mission.eyebrow}</p>
      <h2 class="step-5">{s.mission.heading}</h2>
      <p class="lede">{s.mission.lede}</p>
    </div>
    <div class="mission-image reveal">
      <Image
        src={challengingImage}
        alt="A person navigating everyday life and work in Bangladesh"
        width={1200}
        height={800}
        widths={[500, 800, 1200, 1600]}
        sizes="(max-width: 860px) 100vw, 50vw"
        format="webp"
        quality={70}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .mission {
    background: var(--forest);
    color: var(--on-forest);
    padding-block: clamp(3rem, 7vw, 6rem);
  }
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .eyebrow.light { color: var(--accent-on-forest); }
  h2.step-5 {
    font-size: var(--step-5);
    color: var(--on-forest);
    margin-top: 1rem;
  }
  .mission-copy .lede {
    margin-top: 1.35rem;
    max-width: 46ch;
    color: var(--on-forest-soft);
    font-size: 1.06rem;
  }
  .mission-image img {
    border-radius: var(--radius-lg);
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 16 / 11;
  }
  @media (max-width: 860px) {
    .mission-grid { grid-template-columns: 1fr; }
    .mission-image { order: -1; }
  }
</style>
