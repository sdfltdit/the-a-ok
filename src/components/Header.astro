---
import { t, getLocale, localizedPath } from '../i18n/translations';

const locale = getLocale(Astro.currentLocale);
const s = t(Astro.currentLocale);

const links = [
  { href: `${localizedPath('/', locale)}#explore`, label: s.nav.explore },
  { href: `${localizedPath('/', locale)}#learn`, label: s.nav.learn },
  { href: `${localizedPath('/', locale)}#connect`, label: s.nav.connect },
];

const otherLocale = locale === 'en' ? 'bn' : 'en';
const switchHref = localizedPath('/', otherLocale);
---

<header class="site-header">
  <div class="wrap bar">
    <a href={localizedPath('/', locale)} class="brand" aria-label="The A-OK home">
      <img src="/images/logo-icon.webp" alt="" width="34" height="34" class="brand-mark" />
      <span class="brand-word">The A-OK</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <ul>
        {links.map((l) => (
          <li><a href={l.href}>{l.label}</a></li>
        ))}
      </ul>
    </nav>

    <a
      class="lang-switch"
      href={switchHref}
      data-lang-switch
      data-set-lang={otherLocale}
      lang={otherLocale}
      aria-label={otherLocale === 'bn' ? 'বাংলায় দেখুন' : 'View in English'}
    >
      {s.nav.switchTo}
    </a>

    <a class="btn btn-primary cta" href={`${localizedPath('/', locale)}#join`}>{s.nav.join}</a>

    <button class="menu-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <ul id="mobile-nav" class="mobile-nav">
    {links.map((l) => (
      <li><a href={l.href}>{l.label}</a></li>
    ))}
    <li>
      <a href={switchHref} data-lang-switch data-set-lang={otherLocale} lang={otherLocale}>
        {s.nav.switchTo}
      </a>
    </li>
    <li><a href={`${localizedPath('/', locale)}#join`} class="btn btn-primary">{s.nav.join}</a></li>
  </ul>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(241, 244, 236, 0.78);
    backdrop-filter: blur(14px) saturate(1.4);
    -webkit-backdrop-filter: blur(14px) saturate(1.4);
    border-bottom: 1px solid rgba(16, 56, 41, 0.08);
  }
  @media (prefers-color-scheme: dark) {
    .site-header {
      background: rgba(12, 22, 16, 0.78);
      border-bottom-color: rgba(234, 241, 230, 0.1);
    }
  }
  .bar {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2.5rem);
    padding-block: 0.85rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    color: var(--forest);
    margin-right: auto;
  }
  @media (prefers-color-scheme: dark) {
    .brand { color: var(--ink); }
  }
  .brand-mark {
    border-radius: 9px;
    object-fit: cover;
  }
  .nav ul {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav a {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-soft);
    transition: color 0.25s var(--ease);
  }
  .nav a:hover { color: var(--forest); }
  @media (prefers-color-scheme: dark) {
    .nav a:hover { color: var(--marigold-deep); }
  }
  .cta { flex-shrink: 0; }

  .lang-switch {
    flex-shrink: 0;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--forest);
    border: 1.5px solid currentColor;
    border-radius: 999px;
    padding: 0.5em 1em;
    transition: background 0.25s var(--ease), color 0.25s var(--ease);
  }
  .lang-switch:hover { background: var(--forest); color: var(--paper); }
  @media (prefers-color-scheme: dark) {
    .lang-switch { color: var(--ink); }
    .lang-switch:hover { background: var(--ink); color: var(--paper); }
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    border: none;
    background: transparent;
    border-radius: 10px;
  }
  .menu-toggle span {
    height: 2px;
    background: var(--forest);
    border-radius: 2px;
  }
  @media (prefers-color-scheme: dark) {
    .menu-toggle span { background: var(--ink); }
  }

  .mobile-nav {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0 var(--gutter) 1.25rem;
    flex-direction: column;
    gap: 0.25rem;
  }
  .mobile-nav a {
    display: block;
    padding-block: 0.65rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
  }

  @media (max-width: 760px) {
    .nav, .cta, .bar > .lang-switch { display: none; }
    .menu-toggle { display: flex; }
    .site-header.open .mobile-nav { display: flex; }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const header = document.querySelector('.site-header');
  toggle?.addEventListener('click', () => {
    const isOpen = header?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  // Remember an explicit language choice so the auto-detect redirect
  // in Layout.astro never overrides a deliberate pick on future visits.
  document.querySelectorAll('[data-lang-switch]').forEach((el) => {
    el.addEventListener('click', () => {
      const lang = el.getAttribute('data-set-lang');
      if (lang) {
        try { localStorage.setItem('aok-lang', lang); } catch (e) {}
      }
    });
  });
</script>
