---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The A-OK — Explore. Learn. Connect.',
  description = 'The A-OK is a home base for people across Bangladesh to explore new opportunities, learn real skills, and connect with each other.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#103829" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/hero-poster.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&family=Tiro+Bangla&family=Hind+Siliguri:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Restrained scroll-reveal. Content is visible by default in CSS;
      // this script is the ONLY thing that ever hides it, and only after
      // opting in via html.js-reveal — so a script error or blocked script
      // fails safe into "everything just shows up".
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');

      if (!prefersReduced && revealEls.length) {
        document.documentElement.classList.add('js-reveal');

        const showAllRemaining = () => {
          revealEls.forEach((el) => el.classList.add('is-visible'));
        };

        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
          );
          revealEls.forEach((el) => io.observe(el));
        } else {
          showAllRemaining();
        }

        // Safety net: whatever hasn't revealed itself yet, just show it.
        // Guarantees no section can end up permanently invisible.
        window.setTimeout(showAllRemaining, 1200);
      }
    </script>
  </body>
</html>
