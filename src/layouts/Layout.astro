---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, getLocale } from '../i18n/translations';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const locale = getLocale(Astro.currentLocale);
const strings = t(Astro.currentLocale);

const { title = strings.meta.title, description = strings.meta.description } = Astro.props;
const canonicalPath = locale === 'bn' ? '/bn/' : '/';
---

<!doctype html>
<html lang={locale}>
  <head>
    <script is:inline>
      // Auto-detect language from the OS/browser and redirect, unless the
      // person already picked one explicitly (stored) — runs before any
      // stylesheet/font so the redirect (when needed) happens as early as
      // possible. Fails silently into "just stay on this page" on any error.
      (function () {
        try {
          var path = window.location.pathname;
          var onBn = path === '/bn' || path.indexOf('/bn/') === 0;
          var stored = localStorage.getItem('aok-lang');
          var want = stored;
          if (want !== 'en' && want !== 'bn') {
            var nav = (navigator.languages && navigator.languages[0]) || navigator.language || '';
            want = nav.toLowerCase().indexOf('bn') === 0 ? 'bn' : 'en';
          }
          if (want === 'bn' && !onBn) {
            window.location.replace('/bn' + path);
          } else if (want === 'en' && onBn) {
            window.location.replace(path.replace(/^\/bn/, '') || '/');
          }
        } catch (e) {}
      })();
    </script>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f1f4ec" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0c1610" media="(prefers-color-scheme: dark)" />

    <link rel="canonical" href={`https://sdfltdit.github.io${canonicalPath}`} />
    <link rel="alternate" hreflang="en" href="https://sdfltdit.github.io/" />
    <link rel="alternate" hreflang="bn" href="https://sdfltdit.github.io/bn/" />
    <link rel="alternate" hreflang="x-default" href="https://sdfltdit.github.io/" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/images/hero-poster.jpg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&family=Tiro+Bangla&family=Hind+Siliguri:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="visually-hidden">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Restrained scroll-reveal. Content is visible by default in CSS;
      // this script is the ONLY thing that ever hides it, and only after
      // opting in via html.js-reveal — so a script error or blocked script
      // fails safe into "everything just shows up".
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const revealEls = document.querySelectorAll('.reveal');

      if (!prefersReduced && revealEls.length) {
        document.documentElement.classList.add('js-reveal');

        const showAllRemaining = () => {
          revealEls.forEach((el) => el.classList.add('is-visible'));
        };

        if ('IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible');
                  io.unobserve(entry.target);
                }
              }
            },
            { threshold: 0.15, rootMargin: '0px 0px -8% 0px' }
          );
          revealEls.forEach((el) => io.observe(el));
        } else {
          showAllRemaining();
        }

        // Safety net: whatever hasn't revealed itself yet, just show it.
        // Guarantees no section can end up permanently invisible.
        window.setTimeout(showAllRemaining, 1200);
      }
    </script>
  </body>
</html>
