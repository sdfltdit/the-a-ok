# Security headers, site-wide. This is a fully static site with no
# user-generated content and no dynamic HTML injection anywhere in the
# codebase (verified: no innerHTML/eval/document.write), so a fairly
# strict policy is safe here. 'unsafe-inline' is kept for script/style
# specifically because we intentionally inline the one early language-
# redirect script and the whole (small) stylesheet for speed -- but no
# script or style may load from any OTHER origin.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; media-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; require-trusted-types-for 'script'
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Cross-Origin-Opener-Policy: same-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()

# Cloudflare Pages reads this file automatically (no config needed).
# Astro content-hashes everything under /_astro/, so it's always safe to
# cache those forever. Fonts are pinned to specific weights we chose, so
# they're effectively permanent too. Images/video use a long-but-not-
# immutable cache since their filenames aren't hashed — if they're ever
# replaced, visitors pick up the change within the window below instead
# of needing a filename change.

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=2592000

/video/*
  Cache-Control: public, max-age=2592000

/favicon.ico
  Cache-Control: public, max-age=604800
/favicon-16x16.png
  Cache-Control: public, max-age=604800
/favicon-32x32.png
  Cache-Control: public, max-age=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=604800
/icon-192.png
  Cache-Control: public, max-age=604800
/icon-512.png
  Cache-Control: public, max-age=604800
